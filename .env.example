# Claude Code OAuth Token (Max plan only)
# Generate on your HOST: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-paste-your-token-here

# YouTube Data API v3
# Get from: https://console.cloud.google.com -> Enable "YouTube Data API v3" -> Credentials -> Create API Key
YOUTUBE_API_KEY=

# Google Custom Search API
# Get from: https://console.cloud.google.com -> Enable "Custom Search API" -> Credentials -> Create API Key
GOOGLE_CSE_API_KEY=

# Google Custom Search Engine ID
# Get from: https://programmablesearchengine.google.com -> Create -> Enable "Search the entire web" + "Image search" -> Copy the Search Engine ID
GOOGLE_CSE_ID=
